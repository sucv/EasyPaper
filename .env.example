# LLM Provider API Keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# OpenRouter (optional — use model strings like "openrouter/anthropic/claude-sonnet-4")
OPENROUTER_API_KEY=

# Marker API (Datalab hosted) for PDF OCR
MARKER_API_KEY=

# Ollama — used for both embeddings and LLM if configured
# Local: http://localhost:11434  |  Remote: http://your-server:11434
# Make sure models are pulled: ollama pull llama3.1 && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# Project paths, specify b
PROJECTS_ROOT=./projects
CHROMA_PERSIST_DIR=./chroma_db

# LangSmith (optional — set langsmith_enabled: true in config.yaml)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGSMITH_PROJECT=research-copilot